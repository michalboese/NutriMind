---
title: "NutriMind — System Context Diagram"
---
flowchart TB
    user["<b>Użytkownik</b><br/><i>Śledzi kalorie opisując<br/>posiłki w języku naturalnym</i>"]
    dev["<b>Deweloper / Integrator</b><br/><i>Korzysta z REST API<br/>do integracji</i>"]

    nutrimind["<b>NutriMind</b><br/><i>Aplikacja do śledzenia kalorii<br/>z agentem AI</i>"]

    ollama[("<b>Ollama</b><br/><i>Lokalny serwer LLM<br/>llama3.2</i>")]
    sqlite[("<b>SQLite</b><br/><i>calorie_agent.db</i>")]

    user -- "Gradio UI / HTTP" --> nutrimind
    dev -- "REST API / JSON" --> nutrimind
    nutrimind -- "HTTP POST /api/chat" --> ollama
    nutrimind -- "sqlite3" --> sqlite

    classDef person fill:#08427b,color:#fff,stroke:#073b6f
    classDef system fill:#1168bd,color:#fff,stroke:#0e5aa7
    classDef external fill:#999,color:#fff,stroke:#777

    class user,dev person
    class nutrimind system
    class ollama,sqlite external
