---
title: "NutriMind — Container Diagram"
---
flowchart TB
    user["<b>Użytkownik</b><br/><i>Przeglądarka</i>"]
    dev["<b>Deweloper</b><br/><i>HTTP client</i>"]

    subgraph nutrimind ["NutriMind"]
        gradio["<b>Gradio UI</b><br/><i>Python / Gradio</i><br/>Port 7860"]
        fastapi["<b>FastAPI Backend</b><br/><i>Python / FastAPI</i><br/>Port 8000"]
        agent["<b>Agent Module</b><br/><i>Python / httpx</i><br/>analyze_meal()"]
        db[("<b>SQLite Database</b><br/><i>calorie_agent.db</i><br/>tabela meals")]
    end

    ollama[("<b>Ollama</b><br/><i>Lokalny LLM</i><br/>llama3.2")]

    user -- "HTTP / Browser" --> gradio
    dev -- "HTTP REST / JSON" --> fastapi

    gradio -. "Python import" .-> agent
    gradio -. "Python import / sqlite3" .-> db

    fastapi -. "Python import" .-> agent
    fastapi -. "Python import / sqlite3" .-> db

    agent -- "httpx async<br/>POST /api/chat" --> ollama

    classDef person fill:#08427b,color:#fff,stroke:#073b6f
    classDef container fill:#1168bd,color:#fff,stroke:#0e5aa7
    classDef database fill:#1168bd,color:#fff,stroke:#0e5aa7
    classDef external fill:#999,color:#fff,stroke:#777
    classDef boundary fill:none,stroke:#444,stroke-dasharray:5 5,color:#444

    class user,dev person
    class gradio,fastapi,agent container
    class db database
    class ollama external
    class nutrimind boundary
